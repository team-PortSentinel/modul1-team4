    "# 라이브러리 및 데이터 불러오기\n",
    "import pandas as pd\n",
    "import joblib\n",
    "from sklearn.preprocessing import LabelEncoder\n",
    "from sklearn.feature_extraction.text import TfidfVectorizer\n",
    "from scipy.sparse import csr_matrix, hstack\n",
    "\n",
    "df = pd.read_csv(\n",
    "    \"cve_preprocessed.csv\",\n",
    "    encoding=\"utf-8-sig\"\n",
    ")\n",
    "\n",
    "print(f\"원본 데이터 로드: {len(df)}행\")\n",
    "print(\"데이터 크기:\", df.shape)\n",
    "\n",
    "display(df.head())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "5476766e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "결측치 확인\n",
      "attack_vector          0\n",
      "attack_complexity      0\n",
      "privileges_required    0\n",
      "user_interaction       0\n",
      "cwe                    0\n",
      "description            0\n",
      "severity               0\n",
      "dtype: int64\n"
     ]
    }
   ],
   "source": [
    "# 사용할 Feature 컬럼 정의\n",
    "required_columns = [\n",
    "    \"attack_vector\",\n",
    "    \"attack_complexity\",\n",
    "    \"privileges_required\",\n",
    "    \"user_interaction\",\n",
    "    \"cwe\",\n",
    "    \"description\",\n",
    "    \"severity\",\n",
    "]\n",
    "\n",
    "missing_columns = [\n",
    "    column\n",
    "    for column in required_columns\n",
    "    if column not in df.columns\n",
    "]\n",
    "\n",
    "if missing_columns:\n",
    "    raise ValueError(\n",
    "        f\"필수 컬럼이 없습니다: {missing_columns}\"\n",
    "    )\n",
    "\n",
    "# CWE 및 Description 결측치 처리\n",
    "df[\"cwe\"] = (\n",
    "    df[\"cwe\"]\n",
    "    .fillna(\"UNKNOWN\")\n",
    "    .astype(str)\n",
    "    .str.strip()\n",
    "    .str.upper()\n",
    ")\n",
    "\n",
    "df[\"description\"] = (\n",
    "    df[\"description\"]\n",
    "    .fillna(\"\")\n",
    "    .astype(str)\n",
    "    .str.strip()\n",
    ")\n",
    "\n",
    "print(\"결측치 확인\")\n",
    "print(df[required_columns].isnull().sum())"
   ]
  },
