    "    dtype=int,\n",
    ")\n",
    "\n",
    "print(\"One-Hot Encoding 완료\")\n",
    "print(\"범주형 Feature 크기:\", encoded_features.shape)\n",
    "\n",
    "display(encoded_features.head())"
   ]
